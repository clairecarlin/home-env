#!/bin/bash
(set -o igncr) &>/dev/null && set -o igncr && export SHELLOPTS # ignore cr

unset BASH_ENV # TODO(e-carlin): Necessary?

export HOME_ENV_BASE="$HOME/src/e-carlin/home-env"

_init() {
    local f
    for f in \
        /etc/bashrc \
        /etc/bash.bashrc \
        "$HOME"/src/biviosoftware/home-env/bashrc.d/*.sh \
        "$HOME"/src/e-carlin/home-env/bashrc.d/*.sh \
        ; do
        if [[ -f $f ]]; then
            source "$f"
        fi
    done
    export PYTHONUNBUFFERED=1
}

_init
unset -f _init
